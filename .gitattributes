* text=auto eol=lf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore

# treat Blade templates as PHP so Linguist counts them correctly
*.blade.php linguist-language=PHP

# mark frontend assets as vendored to keep language stats focused on PHP
resources/js/* linguist-vendored
resources/css/* linguist-vendored
public/js/* linguist-vendored
public/css/* linguist-vendored
public/admin/* linguist-vendored
node_modules/* linguist-vendored
